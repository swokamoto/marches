{
  "name": "marches",
  "version": "0.1.0",
  "description": "Campaign management platform for West Marches style tabletop RPG campaigns",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently \"tsx watch src/server.ts\" \"npx @tailwindcss/cli -i src/styles/app.css -o public/css/app.css --watch\"",
    "build": "tsc && npx @tailwindcss/cli -i src/styles/app.css -o public/css/app.css --minify && cp -r src/db/migrations dist/db/migrations",
    "start": "node dist/server.js",
    "db:migrate:prod": "node dist/db/migrate.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "@tailwindcss/cli": "^4.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^26.0.1",
    "@types/nunjucks": "^3.2.6",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.9",
    "chokidar": "^3.6.0",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@types/express-rate-limit": "^5.1.3",
    "bcryptjs": "^3.0.3",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "nunjucks": "^3.2.4",
    "pg": "^8.22.0",
    "postgres": "^3.4.9"
  }
}
