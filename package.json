{
  "name": "marches",
  "version": "0.1.0",
  "description": "Campaign management platform for West Marches style tabletop RPG campaigns",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently \"tsx watch src/server.ts\" \"npx @tailwindcss/cli -i src/styles/app.css -o public/css/app.css --watch\"",
    "build": "tsc && npx @tailwindcss/cli -i src/styles/app.css -o public/css/app.css --minify",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/nunjucks": "^3.2.6",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "express": "^5.2.1",
    "nunjucks": "^3.2.4"
  }
}
