{# Expects: expedition (with locations relation loaded) #}
<div class="bg-stone-900 border border-stone-800 rounded p-4">
  <h3 class="text-xs font-semibold text-stone-500 uppercase tracking-widest mb-3">Locations</h3>

  {% if expedition.locations.length === 0 %}
    <p class="text-stone-700 text-sm">None targeted.</p>
  {% else %}
    <ul class="space-y-1 mb-3">
      {% for el in expedition.locations %}
        <li class="flex items-center justify-between text-sm">
          <a href="/campaigns/{{ campaign.slug }}/locations/{{ el.location.slug }}"
             class="text-stone-300 hover:text-stone-100">{{ el.location.name }}</a>
          {% if member.role in ['gm', 'admin'] and expedition.status in ['recruiting', 'scheduled'] %}
            <form hx-post="/campaigns/{{ campaign.slug }}/expeditions/{{ expedition.id }}/locations/remove"
                  hx-target="#expedition-locations" hx-swap="innerHTML">
              <input type="hidden" name="locationId" value="{{ el.location.id }}" />
              <button type="submit" class="text-stone-700 hover:text-red-500 text-xs ml-2">✕</button>
            </form>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  {% endif %}

  {% if member.role in ['gm', 'admin'] and expedition.status in ['recruiting', 'scheduled'] %}
    <form hx-post="/campaigns/{{ campaign.slug }}/expeditions/{{ expedition.id }}/locations/add"
          hx-target="#expedition-locations" hx-swap="innerHTML" class="flex gap-2 mt-2">
      <select name="locationId"
              class="flex-1 bg-stone-950 border border-stone-700 rounded px-2 py-1 text-sm text-stone-300 focus:outline-none focus:border-stone-500">
        <option value="">— Add location —</option>
        {% for el in campaignLocations %}
          <option value="{{ el.id }}">{{ el.name }}</option>
        {% endfor %}
      </select>
      <button type="submit" class="px-3 py-1 text-sm bg-stone-800 text-stone-300 rounded hover:bg-stone-700 transition-colors">Add</button>
    </form>
  {% endif %}
</div>
