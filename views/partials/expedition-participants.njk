{# Expects: expedition (with participants relation loaded), playerCharacters #}
<div class="bg-stone-900 border border-stone-800 rounded p-4">
  <h3 class="text-xs font-semibold text-stone-500 uppercase tracking-widest mb-3">
    Participants
    <span class="text-stone-700 font-normal normal-case ml-1">({{ expedition.participants.length }})</span>
  </h3>

  {% if expedition.participants.length === 0 %}
    <p class="text-stone-700 text-sm">No one signed up yet.</p>
  {% else %}
    <ul class="space-y-1 mb-3">
      {% for ep in expedition.participants %}
        <li class="flex items-center justify-between text-sm">
          <span class="text-stone-300">
            {{ ep.character.name }}
            <span class="text-stone-600 ml-1">({{ ep.character.player.displayName }})</span>
          </span>
          {% if member.role in ['gm', 'admin'] or ep.character.player.id === user.id %}
            {% if expedition.status in ['recruiting', 'scheduled'] %}
              <form hx-post="/campaigns/{{ campaign.slug }}/expeditions/{{ expedition.id }}/leave"
                    hx-target="#expedition-participants" hx-swap="innerHTML">
                <input type="hidden" name="characterId" value="{{ ep.character.id }}" />
                <button type="submit" class="text-stone-700 hover:text-red-500 text-xs ml-2">✕</button>
              </form>
            {% endif %}
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  {% endif %}

  {# Join form — players see this if they have a character not already in the expedition #}
  {% set alreadyJoined = [] %}
  {% for ep in expedition.participants %}
    {% set alreadyJoined = (alreadyJoined.push(ep.character.id), alreadyJoined) %}
  {% endfor %}

  {% if expedition.status in ['recruiting', 'scheduled'] %}
    {% set availableChars = [] %}
    {% for c in playerCharacters %}
      {% if c.id not in alreadyJoined %}
        {% set availableChars = (availableChars.push(c), availableChars) %}
      {% endif %}
    {% endfor %}

    {% if availableChars.length > 0 %}
      <form hx-post="/campaigns/{{ campaign.slug }}/expeditions/{{ expedition.id }}/join"
            hx-target="#expedition-participants" hx-swap="innerHTML" class="flex gap-2 mt-2">
        <select name="characterId"
                class="flex-1 bg-stone-950 border border-stone-700 rounded px-2 py-1 text-sm text-stone-300 focus:outline-none focus:border-stone-500">
          <option value="">— Join as —</option>
          {% for c in availableChars %}
            <option value="{{ c.id }}">{{ c.name }}</option>
          {% endfor %}
        </select>
        <button type="submit" class="px-3 py-1 text-sm bg-stone-800 text-stone-300 rounded hover:bg-stone-700 transition-colors">Join</button>
      </form>
    {% elif playerCharacters.length === 0 %}
      <p class="text-stone-600 text-xs mt-3">
        You need a character to join.
        <a href="/campaigns/{{ campaign.slug }}/characters/new"
           class="text-stone-400 hover:text-stone-200 underline">Create one</a>.
      </p>
    {% endif %}
  {% endif %}
</div>
