{# Journal entries + add-entry form for any entity #}
{# Expects: entries[], entityType, entityId, campaign (from res.locals) #}

{% set gmEntries = [] %}
{% set playerEntries = [] %}

{% for e in entries %}
  {% if e.authorRole in ['gm', 'admin'] %}
    {% set gmEntries = (gmEntries.push(e), gmEntries) %}
  {% else %}
    {% set playerEntries = (playerEntries.push(e), playerEntries) %}
  {% endif %}
{% endfor %}

{# ── GM Records ── #}
<div class="mb-8">
  <h2 class="text-xs font-semibold text-stone-500 uppercase tracking-widest mb-3">
    GM Records
  </h2>

  {% if gmEntries.length === 0 %}
    <p class="text-stone-700 text-sm">No GM records yet.</p>
  {% else %}
    <div class="space-y-4">
      {% for e in gmEntries %}
        <div class="border-l-2 {% if e.pinned %}border-stone-500{% else %}border-stone-800{% endif %} pl-4">
          <div class="flex items-center gap-2 mb-1">
            {% if e.pinned %}
              <span class="text-stone-500 text-xs">📌</span>
            {% endif %}
            {% if e.campaignDay %}
              <span class="text-xs text-stone-600">Day {{ e.campaignDay }}</span>
            {% endif %}
            <span class="text-xs text-stone-500">{{ e.author.displayName }}</span>
            {% if e.visibility === 'gm_only' %}
              <span class="text-xs text-amber-700">gm only</span>
            {% endif %}
            {% if member.role in ['gm', 'admin'] %}
              {% if e.pinned %}
                <button class="text-xs text-stone-600 hover:text-stone-400 ml-auto"
                  hx-post="/campaigns/{{ campaign.slug }}/journal/{{ entityType }}/{{ entityId }}/{{ e.id }}/unpin"
                  hx-target="closest div[id]" hx-swap="innerHTML">Unpin</button>
              {% else %}
                <button class="text-xs text-stone-600 hover:text-stone-400 ml-auto"
                  hx-post="/campaigns/{{ campaign.slug }}/journal/{{ entityType }}/{{ entityId }}/{{ e.id }}/pin"
                  hx-target="closest div[id]" hx-swap="innerHTML">Pin</button>
              {% endif %}
            {% endif %}
          </div>
          <p class="text-stone-300 text-sm whitespace-pre-wrap">{{ e.body }}</p>
        </div>
      {% endfor %}
    </div>
  {% endif %}
</div>

{# ── Player Notes ── #}
{% if playerEntries.length > 0 %}
  <div class="mb-8">
    <h2 class="text-xs font-semibold text-stone-500 uppercase tracking-widest mb-3">
      Player Notes
    </h2>
    <div class="space-y-4">
      {% for e in playerEntries %}
        <div class="border-l-2 border-stone-800 pl-4">
          <div class="flex items-center gap-2 mb-1">
            {% if e.campaignDay %}
              <span class="text-xs text-stone-600">Day {{ e.campaignDay }}</span>
            {% endif %}
            <span class="text-xs text-stone-500">{{ e.author.displayName }}</span>
            {% if e.visibility === 'private' %}
              <span class="text-xs text-stone-700 italic">private</span>
            {% endif %}
          </div>
          <p class="text-stone-400 text-sm whitespace-pre-wrap">{{ e.body }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
{% endif %}

{# ── Pagination ── #}
{% if totalPages > 1 %}
  <div class="flex items-center justify-between mb-6 text-xs text-stone-600">
    <span>{{ total }} entr{{ 'ies' if total !== 1 else 'y' }}</span>
    <div class="flex items-center gap-2">
      {% if page > 1 %}
        <a hx-get="/campaigns/{{ campaign.slug }}/journal/{{ entityType }}/{{ entityId }}?page={{ page - 1 }}"
           hx-swap="innerHTML" hx-target="closest div[id]"
           class="px-2 py-1 border border-stone-800 rounded hover:border-stone-600 cursor-pointer">← Prev</a>
      {% endif %}
      <span>{{ page }} / {{ totalPages }}</span>
      {% if page < totalPages %}
        <a hx-get="/campaigns/{{ campaign.slug }}/journal/{{ entityType }}/{{ entityId }}?page={{ page + 1 }}"
           hx-swap="innerHTML" hx-target="closest div[id]"
           class="px-2 py-1 border border-stone-800 rounded hover:border-stone-600 cursor-pointer">Next →</a>
      {% endif %}
    </div>
  </div>
{% endif %}

{# ── Add entry form ── #}
<div class="mt-6 border-t border-stone-800 pt-6">
  <h3 class="text-xs font-semibold text-stone-500 uppercase tracking-widest mb-3">
    {% if member.role in ['gm', 'admin'] %}Add Record{% else %}Add Note{% endif %}
  </h3>

  <form
    hx-post="/campaigns/{{ campaign.slug }}/journal/{{ entityType }}/{{ entityId }}"
    hx-target="closest div[id]"
    hx-swap="innerHTML"
    class="space-y-3"
  >
    <textarea
      name="body"
      rows="3"
      required
      placeholder="{% if member.role in ['gm', 'admin'] %}Write a record...{% else %}Write a note...{% endif %}"
      class="w-full bg-stone-900 border border-stone-700 rounded px-3 py-2 text-sm text-stone-100
             focus:outline-none focus:border-stone-500 transition-colors resize-none"
    ></textarea>

    <div class="flex items-center gap-3">
      {% if member.role in ['gm', 'admin'] %}
        <select
          name="visibility"
          class="bg-stone-900 border border-stone-700 rounded px-2 py-1.5 text-sm text-stone-400
                 focus:outline-none focus:border-stone-500"
        >
          <option value="public">Public</option>
          <option value="gm_only">GM only</option>
          <option value="private">Private</option>
        </select>
        <input
          type="number"
          name="campaign_day"
          value="{{ currentCampaignDay }}"
          min="1"
          class="w-20 bg-stone-900 border border-stone-700 rounded px-2 py-1.5 text-sm text-stone-400
                 focus:outline-none focus:border-stone-500"
        />
      {% endif %}
      <button
        type="submit"
        class="px-4 py-1.5 text-sm bg-stone-100 text-stone-900 font-medium rounded hover:bg-white transition-colors"
      >
        Save
      </button>
    </div>
  </form>
</div>
