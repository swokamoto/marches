{# Expects: expedition or exp in context #}
{% set e = expedition if expedition else exp %}
{% if e %}
  {% if e.status === 'recruiting' %}
    <span class="text-xs px-2 py-0.5 rounded border border-blue-900 text-blue-400 bg-blue-950/40">recruiting</span>
  {% elif e.status === 'scheduled' %}
    <span class="text-xs px-2 py-0.5 rounded border border-amber-800 text-amber-400 bg-amber-950/40">scheduled</span>
  {% elif e.status === 'active' %}
    <span class="text-xs px-2 py-0.5 rounded border border-green-800 text-green-400 bg-green-950/40">active</span>
  {% elif e.status === 'completed' %}
    <span class="text-xs px-2 py-0.5 rounded border border-stone-700 text-stone-400">completed</span>
  {% elif e.status === 'cancelled' %}
    <span class="text-xs px-2 py-0.5 rounded border border-red-900 text-red-600">cancelled</span>
  {% endif %}
{% endif %}
