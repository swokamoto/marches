{% extends "layouts/base.njk" %}
{% block content %}

<div class="flex items-center justify-between mb-8">
  <h1 class="text-2xl font-semibold text-stone-100">Timeline</h1>
  <span class="text-xs text-stone-600">{{ events.length }} event{{ 's' if events.length !== 1 }}</span>
</div>

{% if events.length === 0 %}
  <p class="text-stone-600 text-sm">
    No world events yet. They are created when GMs publish session reports.
  </p>
{% else %}
  {# Group by campaign day #}
  {% set currentDay = null %}
  <div class="relative">
    {# Vertical spine #}
    <div class="absolute left-[5.5rem] top-0 bottom-0 w-px bg-stone-800"></div>

    <div class="space-y-0">
      {% for event in events %}
        {% set day = event.campaignDay %}

        {# Day header when day changes #}
        {% if day !== currentDay %}
          {% set currentDay = day %}
          <div class="flex items-center gap-4 pt-8 pb-4 first:pt-0">
            <div class="w-20 text-right shrink-0">
              {% if day %}
                <span class="text-xs font-semibold text-stone-500 uppercase tracking-widest">Day {{ day }}</span>
              {% else %}
                <span class="text-xs text-stone-700 uppercase tracking-widest">Undated</span>
              {% endif %}
            </div>
            <div class="w-3 h-3 rounded-full bg-stone-700 border-2 border-stone-900 shrink-0 relative z-10 ml-2"></div>
          </div>
        {% endif %}

        {# Event row #}
        <div class="flex items-start gap-4 py-2 group">
          <div class="w-20 shrink-0"></div>
          {# Timeline dot #}
          <div class="w-2 h-2 rounded-full bg-stone-600 mt-2 shrink-0 relative z-10 ml-2.5 group-hover:bg-stone-400 transition-colors"></div>

          <div class="flex-1 min-w-0 pb-1">
            <p class="text-stone-200 text-sm font-medium leading-snug">{{ event.title }}</p>
            {% if event.description and event.description !== event.title %}
              <p class="text-stone-500 text-xs mt-0.5">{{ event.description }}</p>
            {% endif %}
            <div class="flex items-center gap-3 mt-1 text-xs text-stone-700">
              {% if event.session %}
                <a href="/campaigns/{{ campaign.slug }}/sessions/{{ event.session.id }}"
                   class="hover:text-stone-500 transition-colors">
                  {{ event.session.expedition.title }}
                </a>
              {% endif %}
              <span>{{ event.createdAt | timeago }}</span>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
{% endif %}

{% endblock %}
