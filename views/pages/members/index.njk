{% extends "layouts/base.njk" %}
{% block content %}

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold text-stone-100">Members</h1>
</div>

{# ── Invite code ── #}
<div class="bg-stone-900 border border-stone-800 rounded p-5 mb-8 max-w-md">
  <h2 class="text-xs font-semibold text-stone-500 uppercase tracking-widest mb-3">Invite Code</h2>
  <div id="invite-code-block">
    {% include "partials/invite-code.njk" %}
  </div>
  <p class="text-stone-600 text-xs mt-3">
    Share this code with players. They can use it at
    <a href="/campaigns/join" class="underline hover:text-stone-400">/campaigns/join</a>.
    Rotate to invalidate the current code.
  </p>
</div>

{# ── Member list ── #}
<div class="max-w-lg">
  <h2 class="text-xs font-semibold text-stone-500 uppercase tracking-widest mb-3">
    {{ memberList.length }} member{{ 's' if memberList.length !== 1 }}
  </h2>

  <div class="space-y-2">
    {% for m in memberList %}
      <div class="flex items-center justify-between bg-stone-900 border border-stone-800 rounded px-4 py-3">
        <div>
          <span class="text-stone-200 text-sm font-medium">{{ m.user.displayName }}</span>
          <span class="text-stone-600 text-xs ml-2">{{ m.user.email }}</span>
        </div>

        <div class="flex items-center gap-3">
          {% if m.user.id !== user.id %}
            {# Role selector #}
            <form method="POST"
                  action="/campaigns/{{ campaign.slug }}/members/{{ m.user.id }}/role"
                  class="flex items-center gap-2">
                    {% include "partials/csrf.njk" %}
              <select name="role"
                      class="bg-stone-950 border border-stone-700 rounded px-2 py-1 text-xs text-stone-300 focus:outline-none focus:border-stone-500">
                {% for r in ['gm', 'player', 'observer'] %}
                  <option value="{{ r }}" {% if m.role === r %}selected{% endif %}>{{ r }}</option>
                {% endfor %}
              </select>
              <button type="submit"
                      class="text-xs text-stone-600 hover:text-stone-400 transition-colors">
                Save
              </button>
            </form>

            {# Remove #}
            <form method="POST"
                  action="/campaigns/{{ campaign.slug }}/members/{{ m.user.id }}/remove"
                  onsubmit="return confirm('Remove {{ m.user.displayName }} from the campaign?')">
                    {% include "partials/csrf.njk" %}
              <button type="submit" class="text-xs text-stone-700 hover:text-red-500 transition-colors">
                Remove
              </button>
            </form>
          {% else %}
            <span class="text-xs text-stone-500 capitalize border border-stone-700 rounded px-2 py-0.5">{{ m.role }} (you)</span>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% endblock %}
