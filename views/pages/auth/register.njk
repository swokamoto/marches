{% extends "layouts/base.njk" %}

{% block content %}
<div class="max-w-sm mx-auto mt-16">
  <h1 class="text-2xl font-semibold text-stone-100 mb-6">Create account</h1>

  {% if error %}
    <p class="text-red-400 text-sm mb-4">{{ error }}</p>
  {% endif %}

  <form method="POST" action="/auth/register" class="space-y-4">
    {% include "partials/csrf.njk" %}

    <div>
      <label for="displayName" class="block text-sm text-stone-400 mb-1">Display name</label>
      <input
        type="text"
        id="displayName"
        name="displayName"
        required
        autocomplete="nickname"
        value="{{ formData.displayName or '' }}"
        class="w-full bg-stone-900 border border-stone-700 rounded px-3 py-2 text-stone-100
               focus:outline-none focus:border-stone-500 transition-colors"
      />
    </div>

    <div>
      <label for="email" class="block text-sm text-stone-400 mb-1">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        autocomplete="email"
        value="{{ formData.email or '' }}"
        class="w-full bg-stone-900 border border-stone-700 rounded px-3 py-2 text-stone-100
               focus:outline-none focus:border-stone-500 transition-colors"
      />
    </div>

    <div>
      <label for="password" class="block text-sm text-stone-400 mb-1">Password</label>
      <input
        type="password"
        id="password"
        name="password"
        required
        minlength="8"
        autocomplete="new-password"
        class="w-full bg-stone-900 border border-stone-700 rounded px-3 py-2 text-stone-100
               focus:outline-none focus:border-stone-500 transition-colors"
      />
      <p class="text-xs text-stone-600 mt-1">Minimum 8 characters</p>
    </div>

    <div>
      <label for="confirmPassword" class="block text-sm text-stone-400 mb-1">Confirm password</label>
      <input
        type="password"
        id="confirmPassword"
        name="confirmPassword"
        required
        autocomplete="new-password"
        class="w-full bg-stone-900 border border-stone-700 rounded px-3 py-2 text-stone-100
               focus:outline-none focus:border-stone-500 transition-colors"
      />
    </div>

    <button
      type="submit"
      class="w-full bg-stone-100 text-stone-900 font-medium py-2 rounded hover:bg-white transition-colors"
    >
      Create account
    </button>

  </form>

  <p class="mt-6 text-sm text-stone-500">
    Already have an account?
    <a href="/auth/login" class="text-stone-300 hover:text-stone-100">Sign in</a>
  </p>
</div>
{% endblock %}
