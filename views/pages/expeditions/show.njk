{% extends "layouts/base.njk" %}
{% block content %}

{# ── Header + status pipeline ── #}
<div class="mb-8">
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-stone-100 mb-1">{{ expedition.title }}</h1>
      <p class="text-stone-500 text-sm">
        GM: {{ expedition.gm.displayName }}
        {% if expedition.scheduledDate %}
          · {{ expedition.scheduledDate | dateformat }}
        {% endif %}
      </p>
    </div>
    <a href="/campaigns/{{ campaign.slug }}/expeditions"
       class="text-xs text-stone-600 hover:text-stone-400 mt-1">← Expeditions</a>
  </div>

  {% if expedition.premise %}
    <p class="mt-4 text-stone-400 text-sm border-l-2 border-stone-700 pl-4 italic">
      {{ expedition.premise }}
    </p>
  {% endif %}
</div>

{# ── Status zone (swapped by HTMX on advance) ── #}
<div id="expedition-status-zone">
  {% include "partials/expedition-status-zone.njk" %}
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mt-8">

  {# ── Locations ── #}
  <div id="expedition-locations">
    {% include "partials/expedition-locations.njk" %}
  </div>

  {# ── NPCs ── #}
  <div id="expedition-npcs">
    {% include "partials/expedition-npcs.njk" %}
  </div>

  {# ── Artifacts ── #}
  <div id="expedition-artifacts">
    {% include "partials/expedition-artifacts.njk" %}
  </div>

  {# ── Participants ── #}
  <div id="expedition-participants">
    {% include "partials/expedition-participants.njk" %}
  </div>

</div>

{# ── Sessions ── #}
<div class="mt-10 border-t border-stone-800 pt-8">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-xs font-semibold text-stone-500 uppercase tracking-widest">Sessions</h2>
    {% if member.role in ['gm', 'admin'] and expedition.status === 'active' %}
      <form method="POST"
            action="/campaigns/{{ campaign.slug }}/expeditions/{{ expedition.id }}/sessions/create"
            class="flex items-center gap-2">
        {% include "partials/csrf.njk" %}
        <input type="number" name="campaign_day" value="{{ currentCampaignDay }}" min="1"
               placeholder="Campaign day"
               class="w-32 bg-stone-900 border border-stone-700 rounded px-3 py-1.5 text-sm text-stone-300 focus:outline-none focus:border-stone-500"/>
        <button type="submit"
                class="px-4 py-1.5 bg-stone-100 text-stone-900 text-sm font-medium rounded hover:bg-white transition-colors">
          + New session
        </button>
      </form>
    {% endif %}
  </div>

  {% if expeditionSessions.length === 0 %}
    <p class="text-stone-600 text-sm">
      {% if expedition.status === 'active' %}No sessions yet — start one above.
      {% else %}Sessions will appear here once the expedition is active.{% endif %}
    </p>
  {% else %}
    <div class="space-y-2">
      {% for s in expeditionSessions %}
        <a href="/campaigns/{{ campaign.slug }}/sessions/{{ s.id }}"
           class="flex items-center justify-between bg-stone-900 border border-stone-800 rounded px-4 py-3 hover:border-stone-700 transition-colors">
          <div class="flex items-center gap-3 text-sm">
            <span class="text-stone-500 text-xs">Session {{ loop.index }}</span>
            <span class="text-stone-400">{{ s.gm.displayName }}</span>
            {% if s.campaignDay %}
              <span class="text-stone-600 text-xs">Day {{ s.campaignDay }}</span>
            {% endif %}
            {% if s.playedAt %}
              <span class="text-stone-600 text-xs">{{ s.playedAt | dateformat }}</span>
            {% endif %}
          </div>
          <span class="text-xs px-2 py-0.5 rounded border capitalize
            {% if s.status === 'active' %}text-yellow-400 border-yellow-800
            {% elif s.status === 'closed' %}text-stone-500 border-stone-700
            {% else %}text-green-400 border-green-800{% endif %}">
            {{ s.status }}
          </span>
        </a>
      {% endfor %}
    </div>
  {% endif %}
</div>

{# ── Conflict warnings (GM/admin only) ── #}
{% if member.role in ['gm', 'admin'] and conflicts.length > 0 %}
  <div class="mt-8">
    <h2 class="text-xs font-semibold text-amber-600 uppercase tracking-widest mb-3">
      ⚠ Scheduling Conflicts
    </h2>
    <div class="space-y-3">
      {% for conflict in conflicts %}
        <div class="border border-amber-900/50 bg-amber-950/20 rounded p-4 text-sm">
          <p class="text-amber-400 font-medium mb-1">
            {{ conflict.type | capitalize }}: {{ conflict.entityName }}
          </p>
          {% for other in conflict.conflictingExpeditions %}
            <p class="text-stone-400">
              Also in
              <a href="/campaigns/{{ campaign.slug }}/expeditions/{{ other.id }}"
                 class="text-stone-200 hover:underline">{{ other.title }}</a>
              (GM: {{ other.gmName }}
              {% if other.scheduledDate %} · {{ other.scheduledDate | dateformat }}{% endif %})
            </p>
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  </div>
{% endif %}

{% endblock %}
