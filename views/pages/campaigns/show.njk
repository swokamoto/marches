{% extends "layouts/base.njk" %}

{% block content %}

{# ── Page header ── #}
<div class="flex items-start justify-between mb-8">
  <div>
    <h1 class="text-2xl font-semibold text-stone-100">{{ campaign.name }}</h1>
    {% if campaign.description %}
      <p class="text-stone-500 text-sm mt-1 max-w-xl">{{ campaign.description }}</p>
    {% endif %}
  </div>

  {% if member.role in ['admin', 'gm'] %}
    <a
      href="/campaigns/{{ campaign.slug }}/expeditions/new"
      class="px-4 py-2 bg-stone-100 text-stone-900 text-sm font-medium rounded hover:bg-white transition-colors shrink-0"
    >
      New expedition
    </a>
  {% endif %}
</div>

{# ── Three-column overview ── #}
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">

  {# Active / upcoming expeditions #}
  <div class="bg-stone-900 border border-stone-800 rounded p-5">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-medium text-stone-400 uppercase tracking-wide">Active Expeditions</h2>
      <a href="/campaigns/{{ campaign.slug }}/expeditions" class="text-xs text-stone-600 hover:text-stone-400">All →</a>
    </div>
    {% if activeExpeditions.length === 0 %}
      <p class="text-stone-600 text-sm text-center py-4">No active expeditions.</p>
    {% else %}
      <div class="space-y-2">
        {% for exp in activeExpeditions %}
          <a href="/campaigns/{{ campaign.slug }}/expeditions/{{ exp.id }}"
             class="flex items-center justify-between text-sm py-1.5 border-b border-stone-800 last:border-0 hover:text-stone-100 transition-colors">
            <span class="text-stone-300">{{ exp.title }}</span>
            <span class="text-xs text-stone-600 capitalize">{{ exp.status }}</span>
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  {# Recent world events #}
  <div class="bg-stone-900 border border-stone-800 rounded p-5">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-medium text-stone-400 uppercase tracking-wide">Recent Events</h2>
      <a href="/campaigns/{{ campaign.slug }}/timeline" class="text-xs text-stone-600 hover:text-stone-400">Timeline →</a>
    </div>
    {% if recentEvents.length === 0 %}
      <p class="text-stone-600 text-sm text-center py-4">No world events yet.</p>
    {% else %}
      <div class="space-y-2">
        {% for event in recentEvents %}
          <div class="text-sm py-1.5 border-b border-stone-800 last:border-0">
            <span class="text-stone-300">{{ event.title }}</span>
            {% if event.campaignDay %}
              <span class="text-xs text-stone-600 ml-2">Day {{ event.campaignDay }}</span>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>

</div>

{# ── Activity feed ── #}
<div class="mt-8">
  <h2 class="text-sm font-medium text-stone-400 uppercase tracking-wide mb-4">
    Recent Activity
  </h2>
  <div
    id="activity-feed"
    hx-get="/campaigns/{{ campaign.slug }}/activity"
    hx-trigger="load, every 30s"
    hx-swap="innerHTML"
    class="space-y-2"
  >
    <p class="text-stone-600 text-sm">Loading activity...</p>
  </div>
</div>

{% endblock %}
