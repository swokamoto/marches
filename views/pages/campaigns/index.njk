{% extends "layouts/base.njk" %}

{% block content %}
<div class="flex items-center justify-between mb-8">
  <h1 class="text-2xl font-semibold text-stone-100">My Campaigns</h1>
  <a
    href="/campaigns/new"
    class="px-4 py-2 bg-stone-100 text-stone-900 text-sm font-medium rounded hover:bg-white transition-colors"
  >
    New campaign
  </a>
</div>

{% if userCampaigns.length === 0 %}
  <div class="border border-dashed border-stone-800 rounded p-12 text-center">
    <p class="text-stone-500 mb-4">You are not a member of any campaigns yet.</p>
    <a href="/campaigns/new" class="text-stone-300 hover:text-stone-100 text-sm">
      Create your first campaign →
    </a>
  </div>
{% else %}
  <div class="grid gap-3">
    {% for c in userCampaigns %}
      <a
        href="/campaigns/{{ c.slug }}"
        class="block bg-stone-900 border border-stone-800 rounded p-5 hover:border-stone-700 transition-colors"
      >
        <div class="flex items-start justify-between">
          <div>
            <h2 class="font-medium text-stone-100">{{ c.name }}</h2>
            {% if c.description %}
              <p class="text-stone-500 text-sm mt-1 line-clamp-2">{{ c.description }}</p>
            {% endif %}
          </div>
          <span class="text-xs text-stone-600 border border-stone-800 rounded px-2 py-0.5 ml-4 shrink-0">
            {{ c.role }}
          </span>
        </div>
      </a>
    {% endfor %}
  </div>
{% endif %}
{% endblock %}
