{% extends "layouts/base.njk" %}
{% block content %}
<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold text-stone-100">NPCs</h1>
  {% if member.role in ['gm', 'admin'] %}
    <a href="/campaigns/{{ campaign.slug }}/npcs/new"
       class="px-4 py-2 bg-stone-100 text-stone-900 text-sm font-medium rounded hover:bg-white transition-colors">
      New NPC
    </a>
  {% endif %}
</div>

{% if npcList.length === 0 and page === 1 %}
  <div class="border border-dashed border-stone-800 rounded p-12 text-center">
    <p class="text-stone-500">No NPCs recorded yet.</p>
  </div>
{% else %}
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {% for npc in npcList %}
      <a href="/campaigns/{{ campaign.slug }}/npcs/{{ npc.id }}"
         class="block bg-stone-900 border border-stone-800 rounded p-5 hover:border-stone-700 transition-colors">
        <div class="flex items-start justify-between gap-3">
          <span class="font-medium text-stone-100">{{ npc.name }}</span>
          <div class="flex items-center gap-1 shrink-0">
            {% if isGm and not npc.revealed %}
              <span class="text-xs px-1.5 py-0.5 rounded border border-stone-700 text-stone-600">hidden</span>
            {% endif %}
            {% include "partials/npc-status-badge.njk" %}
          </div>
        </div>
        {% if npc.description %}
          <p class="text-xs text-stone-600 mt-1 truncate">{{ npc.description }}</p>
        {% elif npc.faction %}
          <p class="text-xs text-stone-600 mt-1">{{ npc.faction.name }}</p>
        {% elif npc.location %}
          <p class="text-xs text-stone-600 mt-1">@ {{ npc.location.name }}</p>
        {% endif %}
      </a>
    {% endfor %}
  </div>

  {% if totalPages > 1 %}
    <div class="flex items-center justify-between mt-6 text-sm text-stone-500">
      <span>{{ total }} NPC{{ 's' if total !== 1 }}</span>
      <div class="flex items-center gap-2">
        {% if page > 1 %}
          <a href="?page={{ page - 1 }}" class="px-3 py-1.5 border border-stone-700 rounded hover:border-stone-500 transition-colors">← Prev</a>
        {% endif %}
        <span class="text-stone-600">{{ page }} / {{ totalPages }}</span>
        {% if page < totalPages %}
          <a href="?page={{ page + 1 }}" class="px-3 py-1.5 border border-stone-700 rounded hover:border-stone-500 transition-colors">Next →</a>
        {% endif %}
      </div>
    </div>
  {% endif %}
{% endif %}
{% endblock %}
