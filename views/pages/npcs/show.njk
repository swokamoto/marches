{% extends "layouts/base.njk" %}
{% block content %}
<div class="flex items-start justify-between mb-8">
  <div>
    <div class="flex items-center gap-3 mb-1">
      <h1 class="text-2xl font-semibold text-stone-100">{{ npc.name }}</h1>
      <div id="npc-status-badge">{% include "partials/npc-status-badge.njk" %}</div>
    </div>
    {% if npc.description %}
      <p class="text-stone-400 text-sm mb-1">{{ npc.description }}</p>
    {% endif %}
    <a href="/campaigns/{{ campaign.slug }}/npcs" class="text-xs text-stone-600 hover:text-stone-400">← All NPCs</a>
  </div>
</div>

{% if member.role in ['gm', 'admin'] %}
  <div class="mb-8 flex flex-wrap items-center gap-6">
    <div class="flex items-center gap-3">
      <span class="text-sm text-stone-500">Status:</span>
      <form hx-post="/campaigns/{{ campaign.slug }}/npcs/{{ npc.id }}/status"
            hx-target="#npc-status-badge" hx-swap="innerHTML" class="flex items-center gap-2">
        <select name="status" class="bg-stone-900 border border-stone-700 rounded px-3 py-1.5 text-sm text-stone-300 focus:outline-none focus:border-stone-500">
          {% for s in ['alive', 'dead', 'missing', 'unknown'] %}
            <option value="{{ s }}" {% if npc.status === s %}selected{% endif %}>{{ s }}</option>
          {% endfor %}
        </select>
        <button type="submit" class="px-3 py-1.5 text-sm border border-stone-700 text-stone-400 rounded hover:border-stone-500 transition-colors">Save</button>
      </form>
    </div>

    <div class="flex items-center gap-3">
      <span class="text-sm text-stone-500">Location:</span>
      <form method="POST" action="/campaigns/{{ campaign.slug }}/npcs/{{ npc.id }}/location"
            class="flex items-center gap-2">
              {% include "partials/csrf.njk" %}
        <select name="location_id"
                class="bg-stone-900 border border-stone-700 rounded px-3 py-1.5 text-sm text-stone-300 focus:outline-none focus:border-stone-500">
          <option value="">— None —</option>
          {% for loc in campaignLocations %}
            <option value="{{ loc.id }}" {% if npc.locationId === loc.id %}selected{% endif %}>{{ loc.name }}</option>
          {% endfor %}
        </select>
        <button type="submit" class="px-3 py-1.5 text-sm border border-stone-700 text-stone-400 rounded hover:border-stone-500 transition-colors">Save</button>
      </form>
      {% if npc.locationId %}
        {% for loc in campaignLocations %}
          {% if loc.id === npc.locationId %}
            <a href="/campaigns/{{ campaign.slug }}/locations/{{ loc.slug }}"
               class="text-xs text-stone-400 hover:text-stone-200 transition-colors">→ {{ loc.name }}</a>
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>

    <div class="flex items-center gap-3">
      <span class="text-sm text-stone-500">Faction:</span>
      <form method="POST" action="/campaigns/{{ campaign.slug }}/npcs/{{ npc.id }}/faction"
            class="flex items-center gap-2">
        {% include "partials/csrf.njk" %}
        <select name="faction_id" class="bg-stone-900 border border-stone-700 rounded px-3 py-1.5 text-sm text-stone-300 focus:outline-none focus:border-stone-500">
          <option value="">— None —</option>
          {% for f in factionList %}
            <option value="{{ f.id }}" {% if npc.factionId === f.id %}selected{% endif %}>{{ f.name }}</option>
          {% endfor %}
        </select>
        <button type="submit" class="px-3 py-1.5 text-sm border border-stone-700 text-stone-400 rounded hover:border-stone-500 transition-colors">Save</button>
      </form>
      {% if npc.faction %}
        <a href="/campaigns/{{ campaign.slug }}/factions/{{ npc.faction.id }}"
           class="text-xs text-stone-400 hover:text-stone-200 transition-colors">→ {{ npc.faction.name }}</a>
      {% endif %}
    </div>

    <form method="POST" action="/campaigns/{{ campaign.slug }}/npcs/{{ npc.id }}/reveal"
          class="flex items-center gap-3">
      {% include "partials/csrf.njk" %}
      <input type="hidden" name="revealed" value="{{ 'false' if npc.revealed else 'true' }}"/>
      <span class="text-sm {{ 'text-green-400' if npc.revealed else 'text-stone-500' }}">
        {{ 'Visible to players' if npc.revealed else 'Hidden from players' }}
      </span>
      <button type="submit" class="px-3 py-1.5 text-sm border border-stone-700 text-stone-400 rounded hover:border-stone-500 transition-colors">
        {{ 'Hide' if npc.revealed else 'Reveal' }}
      </button>
    </form>

    <form method="POST" action="/campaigns/{{ campaign.slug }}/npcs/{{ npc.id }}/archive"
          onsubmit="return confirm('Archive {{ npc.name }}? They will be hidden from all lists.')">
            {% include "partials/csrf.njk" %}
      <button type="submit" class="px-3 py-1.5 text-sm border border-stone-800 text-stone-600 rounded hover:border-red-800 hover:text-red-500 transition-colors">Archive</button>
    </form>
  </div>

  {# Description edit #}
  <div class="mb-8">
    <form method="POST" action="/campaigns/{{ campaign.slug }}/npcs/{{ npc.id }}/description"
          class="flex items-end gap-2">
            {% include "partials/csrf.njk" %}
      <div class="flex-1">
        <label class="block text-xs text-stone-600 mb-1">Brief description</label>
        <input type="text" name="description" value="{{ npc.description or '' }}"
               placeholder="Short description of this NPC"
               class="w-full bg-stone-900 border border-stone-700 rounded px-3 py-1.5 text-sm text-stone-300
                      focus:outline-none focus:border-stone-500 transition-colors"/>
      </div>
      <button type="submit" class="px-3 py-1.5 text-sm border border-stone-700 text-stone-400 rounded hover:border-stone-500 transition-colors">Save</button>
    </form>
  </div>
{% elif npc.locationId %}
  <div class="mb-6">
    <span class="text-xs text-stone-600">Last known location:</span>
    {% for loc in campaignLocations %}
      {% if loc.id === npc.locationId %}
        <a href="/campaigns/{{ campaign.slug }}/locations/{{ loc.slug }}"
           class="text-xs text-stone-400 hover:text-stone-200 ml-1">{{ loc.name }}</a>
      {% endif %}
    {% endfor %}
    {% if npc.faction %}
      <span class="text-stone-700 mx-1">·</span>
      <span class="text-xs text-stone-600">Faction:</span>
      <a href="/campaigns/{{ campaign.slug }}/factions/{{ npc.faction.id }}"
         class="text-xs text-stone-400 hover:text-stone-200 ml-1">{{ npc.faction.name }}</a>
    {% endif %}
  </div>
{% elif npc.faction %}
  <div class="mb-6">
    <span class="text-xs text-stone-600">Faction:</span>
    <a href="/campaigns/{{ campaign.slug }}/factions/{{ npc.faction.id }}"
       class="text-xs text-stone-400 hover:text-stone-200 ml-1">{{ npc.faction.name }}</a>
  </div>
{% endif %}

{% if npc.artifacts.length > 0 %}
<div class="mb-8">
  <h2 class="text-xs font-semibold text-stone-500 uppercase tracking-widest mb-3">Carrying</h2>
  <div class="flex flex-wrap gap-2">
    {% for artifact in npc.artifacts %}
      <a href="/campaigns/{{ campaign.slug }}/artifacts/{{ artifact.id }}"
         class="text-sm text-stone-300 bg-stone-900 border border-stone-800 rounded px-3 py-1
                hover:border-stone-700 transition-colors flex items-center gap-2">
        {{ artifact.name }}
        <span class="text-xs text-stone-600">{{ artifact.status }}</span>
      </a>
    {% endfor %}
  </div>
</div>
{% endif %}

<div id="journal-section">
  <div
    hx-get="/campaigns/{{ campaign.slug }}/journal/npc/{{ npc.id }}"
    hx-trigger="load" hx-swap="outerHTML"
    hx-on::error="this.innerHTML='<p class=text-red-700 text-sm>Failed to load records.</p>'">
    <p class="text-stone-600 text-sm htmx-indicator">Loading records...</p>
  </div>
</div>
{% endblock %}
