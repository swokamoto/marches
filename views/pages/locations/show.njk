{% extends "layouts/base.njk" %}

{% block content %}

{# ── Header ── #}
<div class="flex items-start justify-between mb-8">
  <div>
    <div class="flex items-center gap-3 mb-1">
      <h1 class="text-2xl font-semibold text-stone-100">{{ location.name }}</h1>
      <div id="location-status-badge">
        {% include "partials/location-status-badge.njk" %}
      </div>
    </div>
    <a
      href="/campaigns/{{ campaign.slug }}/locations"
      class="text-xs text-stone-600 hover:text-stone-400"
    >
      ← All locations
    </a>
  </div>
</div>

{# ── Status update (GM/admin only) ── #}
{% if member.role in ['gm', 'admin'] %}
  <div class="mb-8 flex items-center gap-3">
    <span class="text-sm text-stone-500">Update status:</span>
    <form
      hx-post="/campaigns/{{ campaign.slug }}/locations/{{ location.slug }}/status"
      hx-target="#location-status-badge"
      hx-swap="innerHTML"
      class="flex items-center gap-2"
    >
      <select
        name="status"
        class="bg-stone-900 border border-stone-700 rounded px-3 py-1.5 text-sm text-stone-300
               focus:outline-none focus:border-stone-500"
      >
        {% for s in ['open', 'active', 'ruined', 'destroyed', 'unknown'] %}
          <option value="{{ s }}" {% if location.status === s %}selected{% endif %}>{{ s }}</option>
        {% endfor %}
      </select>
      <button
        type="submit"
        class="px-3 py-1.5 text-sm border border-stone-700 text-stone-400 rounded
               hover:border-stone-500 transition-colors"
      >
        Save
      </button>
    </form>
  </div>
{% endif %}

{# ── Journal entries ── #}
<div id="journal-section">
  <div
    hx-get="/campaigns/{{ campaign.slug }}/journal/location/{{ location.id }}"
    hx-trigger="load"
    hx-swap="outerHTML"
    hx-on::error="this.innerHTML='<p class=text-red-700 text-sm>Failed to load records.</p>'"
  >
    <p class="text-stone-600 text-sm htmx-indicator">Loading records...</p>
  </div>
</div>

{# ── Appeared in expeditions (stub) ── #}
<div class="mt-10">
  <h2 class="text-sm font-medium text-stone-500 uppercase tracking-wide mb-3">
    Appeared In
  </h2>
  <p class="text-stone-700 text-sm">No expeditions recorded yet.</p>
</div>

{% endblock %}
