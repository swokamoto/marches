{% extends "layouts/base.njk" %}

{% block content %}
<div class="max-w-lg">
  <h1 class="text-2xl font-semibold text-stone-100 mb-1">New Location</h1>
  <p class="text-stone-500 text-sm mb-8">
    Add a place to the world. Description and notes can be added afterwards via journal entries.
  </p>

  <form method="POST" action="/campaigns/{{ campaign.slug }}/locations/new" class="space-y-5">

    <div>
      <label for="name" class="block text-sm text-stone-400 mb-1">Name</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        placeholder="Black Marsh"
        class="w-full bg-stone-900 border border-stone-700 rounded px-3 py-2 text-stone-100
               focus:outline-none focus:border-stone-500 transition-colors"
      />
    </div>

    {% if allLocations.length > 0 %}
      <div>
        <label for="parent_location_id" class="block text-sm text-stone-400 mb-1">
          Part of <span class="text-stone-600">(optional)</span>
        </label>
        <select id="parent_location_id" name="parent_location_id"
                class="w-full bg-stone-900 border border-stone-700 rounded px-3 py-2 text-stone-300
                       focus:outline-none focus:border-stone-500 transition-colors">
          <option value="">— None —</option>
          {% for loc in allLocations %}
            <option value="{{ loc.id }}">{{ loc.name }}</option>
          {% endfor %}
        </select>
      </div>
    {% endif %}

    <div class="flex gap-3 pt-2">
      <button
        type="submit"
        class="px-5 py-2 bg-stone-100 text-stone-900 font-medium rounded hover:bg-white transition-colors"
      >
        Create location
      </button>
      <a
        href="/campaigns/{{ campaign.slug }}/locations"
        class="px-5 py-2 border border-stone-700 text-stone-400 rounded hover:border-stone-500 transition-colors"
      >
        Cancel
      </a>
    </div>

  </form>
</div>
{% endblock %}
