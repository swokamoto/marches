{% extends "layouts/base.njk" %}
{% block content %}
<div class="flex items-start justify-between mb-8">
  <div>
    <div class="flex items-center gap-3 mb-1">
      <h1 class="text-2xl font-semibold text-stone-100">{{ artifact.name }}</h1>
      <div id="artifact-status-badge">{% include "partials/artifact-status-badge.njk" %}</div>
    </div>
    <a href="/campaigns/{{ campaign.slug }}/artifacts" class="text-xs text-stone-600 hover:text-stone-400">← All artifacts</a>
  </div>
</div>

{% if member.role in ['gm', 'admin'] %}
  <div class="mb-8 flex flex-wrap items-center gap-6">
    <div class="flex items-center gap-3">
      <span class="text-sm text-stone-500">Status:</span>
      <form hx-post="/campaigns/{{ campaign.slug }}/artifacts/{{ artifact.id }}/status"
            hx-target="#artifact-status-badge" hx-swap="innerHTML" class="flex items-center gap-2">
        <select name="status" class="bg-stone-900 border border-stone-700 rounded px-3 py-1.5 text-sm text-stone-300 focus:outline-none focus:border-stone-500">
          {% for s in ['extant', 'lost', 'destroyed', 'unknown'] %}
            <option value="{{ s }}" {% if artifact.status === s %}selected{% endif %}>{{ s }}</option>
          {% endfor %}
        </select>
        <button type="submit" class="px-3 py-1.5 text-sm border border-stone-700 text-stone-400 rounded hover:border-stone-500 transition-colors">Save</button>
      </form>
    </div>

    <div class="flex items-center gap-3">
      <span class="text-sm text-stone-500">Location:</span>
      <form method="POST" action="/campaigns/{{ campaign.slug }}/artifacts/{{ artifact.id }}/location"
            class="flex items-center gap-2">
        <select name="location_id"
                class="bg-stone-900 border border-stone-700 rounded px-3 py-1.5 text-sm text-stone-300 focus:outline-none focus:border-stone-500">
          <option value="">— None —</option>
          {% for loc in campaignLocations %}
            <option value="{{ loc.id }}" {% if artifact.locationId === loc.id %}selected{% endif %}>{{ loc.name }}</option>
          {% endfor %}
        </select>
        <button type="submit" class="px-3 py-1.5 text-sm border border-stone-700 text-stone-400 rounded hover:border-stone-500 transition-colors">Save</button>
      </form>
    </div>

    <form method="POST" action="/campaigns/{{ campaign.slug }}/artifacts/{{ artifact.id }}/archive"
          onsubmit="return confirm('Archive {{ artifact.name }}? It will be hidden from all lists.')">
      <button type="submit" class="px-3 py-1.5 text-sm border border-stone-800 text-stone-600 rounded hover:border-red-800 hover:text-red-500 transition-colors">Archive</button>
    </form>
  </div>
{% elif artifact.locationId %}
  <div class="mb-6">
    <span class="text-xs text-stone-600">Last known location:</span>
    {% for loc in campaignLocations %}
      {% if loc.id === artifact.locationId %}
        <a href="/campaigns/{{ campaign.slug }}/locations/{{ loc.slug }}"
           class="text-xs text-stone-400 hover:text-stone-200 ml-1">{{ loc.name }}</a>
      {% endif %}
    {% endfor %}
  </div>
{% endif %}

<div id="journal-section"
     hx-get="/campaigns/{{ campaign.slug }}/journal/artifact/{{ artifact.id }}"
     hx-trigger="load" hx-swap="outerHTML"
     hx-on::error="this.innerHTML='<p class=text-red-700 text-sm>Failed to load records.</p>'">
  <p class="text-stone-600 text-sm htmx-indicator">Loading records...</p>
</div>
{% endblock %}
