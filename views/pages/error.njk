{% extends "layouts/base.njk" %}

{% block content %}
<div class="max-w-lg mx-auto mt-24 text-center">
  <p class="text-4xl font-semibold text-stone-700 mb-4">{{ status or "Error" }}</p>
  <p class="text-stone-400 text-lg mb-8">{{ message or "Something went wrong." }}</p>
  <div class="flex items-center justify-center gap-4 text-sm">
    {% if campaign %}
      <a href="/campaigns/{{ campaign.slug }}" class="text-stone-400 hover:text-stone-100">← Campaign</a>
    {% endif %}
    <a href="/dashboard" class="text-stone-600 hover:text-stone-400">Dashboard</a>
  </div>
</div>
{% endblock %}
