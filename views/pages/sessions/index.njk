{% extends "layouts/base.njk" %}

{% block content %}
<div class="flex items-center justify-between mb-6">
  <div>
    <a href="/campaigns/{{ campaign.slug }}" class="text-xs text-stone-600 hover:text-stone-400">← {{ campaign.name }}</a>
    <h1 class="text-2xl font-bold mt-1">Sessions</h1>
  </div>
</div>

{% if sessions.length == 0 %}
  <p class="text-stone-500 text-sm">No sessions yet. Sessions are created from expedition pages.</p>
{% else %}
  <div class="space-y-3">
    {% for session in sessions %}
      <a href="/campaigns/{{ campaign.slug }}/sessions/{{ session.id }}"
         class="block bg-stone-900 border border-stone-800 rounded-lg px-5 py-4 hover:border-stone-600 transition-colors">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-3 flex-wrap">
              <span class="text-stone-100 font-medium truncate">
                {% if session.expedition %}{{ session.expedition.title }}{% else %}Unknown expedition{% endif %}
              </span>
              <span class="text-xs px-2 py-0.5 rounded-full border
                {% if session.status == 'active' %}text-yellow-300 border-yellow-700 bg-yellow-900/30
                {% elif session.status == 'published' %}text-green-300 border-green-700 bg-green-900/30
                {% elif session.status == 'closed' %}text-stone-400 border-stone-700 bg-stone-800/40
                {% else %}text-stone-400 border-stone-700{% endif %}">
                {{ session.status }}
              </span>
            </div>
            <div class="text-sm text-stone-500 mt-1">
              GM: {{ session.gm.displayName }}
              {% if session.campaignDay %} · Day {{ session.campaignDay }}{% endif %}
              · {{ session.playedAt | date("mmm d, yyyy") }}
            </div>
          </div>
          <span class="text-stone-600 text-xs shrink-0">{{ session.createdAt | timeago }}</span>
        </div>
      </a>
    {% endfor %}
  </div>
{% endif %}
{% endblock %}
