{% extends "layouts/base.njk" %}
{% block content %}

<div class="max-w-lg">
  <h1 class="text-2xl font-semibold text-stone-100 mb-2">Publish Report</h1>
  <p class="text-stone-500 text-sm mb-8">
    This will create world events and update entity statuses. This cannot be undone.
  </p>

  {% set pending = [] %}
  {% if session.report %}
    {% for c in session.report.worldChanges %}
      {% if c.status === 'pending' %}
        {% set pending = (pending.push(c), pending) %}
      {% endif %}
    {% endfor %}
  {% endif %}

  {% if pending.length === 0 %}
    <div class="bg-stone-900 border border-stone-800 rounded p-6 mb-6">
      <p class="text-stone-500 text-sm">No pending world changes. The report will publish with no world events.</p>
    </div>
  {% else %}
    <div class="bg-stone-900 border border-stone-800 rounded p-5 mb-6">
      <h2 class="text-xs font-semibold text-stone-500 uppercase tracking-widest mb-3">
        This will create {{ pending.length }} world event(s):
      </h2>
      <ul class="space-y-2">
        {% for change in pending %}
          <li class="text-sm text-stone-300 border-l-2 border-stone-700 pl-3">
            <span class="text-stone-500 text-xs capitalize mr-2">{{ change.changeType | replace("_", " ") }}</span>
            {{ change.description }}
          </li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}

  <div class="flex gap-3">
    <form method="POST" action="/campaigns/{{ campaign.slug }}/sessions/{{ session.id }}/publish">
      {% include "partials/csrf.njk" %}
      <button type="submit"
              class="px-5 py-2 bg-stone-100 text-stone-900 font-medium rounded hover:bg-white transition-colors">
        Confirm Publish
      </button>
    </form>
    <a href="/campaigns/{{ campaign.slug }}/sessions/{{ session.id }}"
       class="px-5 py-2 border border-stone-700 text-stone-400 rounded hover:border-stone-500 transition-colors">
      Cancel
    </a>
  </div>
</div>

{% endblock %}
