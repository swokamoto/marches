{% extends "layouts/base.njk" %}
{% block content %}

<div class="flex items-start justify-between mb-8">
  <div>
    <div class="flex items-center gap-3 mb-1">
      <h1 class="text-2xl font-semibold text-stone-100">{{ character.name }}</h1>
      <div id="character-status-badge">{% include "partials/character-status-badge.njk" %}</div>
    </div>
    <p class="text-xs text-stone-600">
      Played by {{ character.player.displayName }}
    </p>
    <a href="/campaigns/{{ campaign.slug }}/characters" class="text-xs text-stone-600 hover:text-stone-400 mt-1 inline-block">← All Characters</a>
  </div>

  {% if isOwner or isGm %}
    <a href="/campaigns/{{ campaign.slug }}/characters/{{ character.id }}/edit"
       class="text-xs text-stone-600 hover:text-stone-400">Edit</a>
  {% endif %}
</div>

{% if character.description %}
  <div class="mb-8 text-stone-400 text-sm max-w-xl whitespace-pre-wrap">{{ character.description }}</div>
{% endif %}

{# GM status control #}
{% if isGm %}
  <div class="mb-8 flex flex-wrap items-center gap-4">
    <div class="flex items-center gap-3">
      <span class="text-sm text-stone-500">Status:</span>
      <form hx-post="/campaigns/{{ campaign.slug }}/characters/{{ character.id }}/status"
            hx-target="#character-status-badge" hx-swap="innerHTML"
            class="flex items-center gap-2">
        <select name="status"
                class="bg-stone-900 border border-stone-700 rounded px-3 py-1.5 text-sm text-stone-300 focus:outline-none focus:border-stone-500">
          {% for s in ['active', 'retired', 'dead'] %}
            <option value="{{ s }}" {% if character.status === s %}selected{% endif %}>{{ s }}</option>
          {% endfor %}
        </select>
        <button type="submit"
                class="px-3 py-1.5 text-sm border border-stone-700 text-stone-400 rounded hover:border-stone-500 transition-colors">
          Save
        </button>
      </form>
    </div>

    <form method="POST" action="/campaigns/{{ campaign.slug }}/characters/{{ character.id }}/archive"
          onsubmit="return confirm('Archive {{ character.name }}? They will be hidden from all lists.')">
            {% include "partials/csrf.njk" %}
      <button type="submit" class="px-3 py-1.5 text-sm border border-stone-800 text-stone-600 rounded hover:border-red-800 hover:text-red-500 transition-colors">Archive</button>
    </form>
  </div>
{% elif isOwner %}
  <div class="mb-8">
    <form method="POST" action="/campaigns/{{ campaign.slug }}/characters/{{ character.id }}/archive"
          onsubmit="return confirm('Archive {{ character.name }}? They will be hidden from all lists.')">
            {% include "partials/csrf.njk" %}
      <button type="submit" class="px-3 py-1.5 text-sm border border-stone-800 text-stone-600 rounded hover:border-red-800 hover:text-red-500 transition-colors">Archive character</button>
    </form>
  </div>
{% endif %}

{# Journal entries for this character #}
<div id="journal-section"
     hx-get="/campaigns/{{ campaign.slug }}/journal/character/{{ character.id }}"
     hx-trigger="load" hx-swap="outerHTML"
     hx-on::error="this.innerHTML='<p class=text-red-700 text-sm>Failed to load records.</p>'">
  <p class="text-stone-600 text-sm htmx-indicator">Loading records...</p>
</div>

{% endblock %}
