{% extends "layouts/base.njk" %}
{% block content %}
<div class="flex items-start justify-between mb-8">
  <div>
    <div class="flex items-center gap-3 mb-1">
      <h1 class="text-2xl font-semibold text-stone-100">{{ faction.name }}</h1>
      <span class="text-xs px-2 py-0.5 rounded-full border
        {% if faction.status === 'active' %}border-green-800 text-green-400
        {% elif faction.status === 'disbanded' %}border-stone-700 text-stone-500
        {% else %}border-stone-700 text-stone-500{% endif %}">
        {{ faction.status }}
      </span>
    </div>
    {% if faction.description %}
      <p class="text-stone-400 text-sm mb-1">{{ faction.description }}</p>
    {% endif %}
    <a href="/campaigns/{{ campaign.slug }}/factions" class="text-xs text-stone-600 hover:text-stone-400">← All Factions</a>
  </div>
</div>

{% if isGm %}
  <div class="mb-8 flex flex-wrap items-center gap-6">
    <div class="flex items-center gap-3">
      <span class="text-sm text-stone-500">Status:</span>
      <form method="POST" action="/campaigns/{{ campaign.slug }}/factions/{{ faction.id }}/status"
            class="flex items-center gap-2">
        {% include "partials/csrf.njk" %}
        <select name="status" class="bg-stone-900 border border-stone-700 rounded px-3 py-1.5 text-sm text-stone-300 focus:outline-none focus:border-stone-500">
          {% for s in ['active', 'disbanded', 'unknown'] %}
            <option value="{{ s }}" {% if faction.status === s %}selected{% endif %}>{{ s }}</option>
          {% endfor %}
        </select>
        <button type="submit" class="px-3 py-1.5 text-sm border border-stone-700 text-stone-400 rounded hover:border-stone-500 transition-colors">Save</button>
      </form>
    </div>

    <form method="POST" action="/campaigns/{{ campaign.slug }}/factions/{{ faction.id }}/archive"
          onsubmit="return confirm('Archive {{ faction.name }}? They will be hidden from all lists.')">
      {% include "partials/csrf.njk" %}
      <button type="submit" class="px-3 py-1.5 text-sm border border-stone-800 text-stone-600 rounded hover:border-red-800 hover:text-red-500 transition-colors">Archive</button>
    </form>
  </div>

  <div class="mb-8">
    <form method="POST" action="/campaigns/{{ campaign.slug }}/factions/{{ faction.id }}/description"
          class="flex items-end gap-2">
      {% include "partials/csrf.njk" %}
      <div class="flex-1">
        <label class="block text-xs text-stone-600 mb-1">Brief description</label>
        <input type="text" name="description" value="{{ faction.description or '' }}"
               placeholder="Short description of this faction"
               class="w-full bg-stone-900 border border-stone-700 rounded px-3 py-1.5 text-sm text-stone-300
                      focus:outline-none focus:border-stone-500 transition-colors"/>
      </div>
      <button type="submit" class="px-3 py-1.5 text-sm border border-stone-700 text-stone-400 rounded hover:border-stone-500 transition-colors">Save</button>
    </form>
  </div>
{% endif %}

{# Members #}
<div>
  <h2 class="text-sm font-medium text-stone-400 mb-3">Members</h2>
  {% if faction.npcs.length === 0 %}
    <p class="text-stone-600 text-sm">No NPCs assigned to this faction yet.</p>
  {% else %}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {% for npc in faction.npcs %}
        <a href="/campaigns/{{ campaign.slug }}/npcs/{{ npc.id }}"
           class="block bg-stone-900 border border-stone-800 rounded px-4 py-3 hover:border-stone-700 transition-colors">
          <div class="flex items-center justify-between gap-3">
            <span class="text-sm text-stone-100">{{ npc.name }}</span>
            <span class="text-xs text-stone-500">{{ npc.status }}</span>
          </div>
        </a>
      {% endfor %}
    </div>
  {% endif %}
</div>
{% endblock %}
