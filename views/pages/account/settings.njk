{% extends "layouts/base.njk" %}
{% block content %}
<div class="max-w-lg">
  <h1 class="text-2xl font-semibold text-stone-100 mb-8">Account Settings</h1>

  {# ── Display name ── #}
  <section class="mb-10">
    <h2 class="text-xs font-semibold text-stone-500 uppercase tracking-widest mb-4">Profile</h2>
    <form method="POST" action="/account" class="space-y-4">
      {% include "partials/csrf.njk" %}
      <div>
        <label for="displayName" class="block text-sm text-stone-400 mb-1">Display name</label>
        <input
          type="text"
          id="displayName"
          name="displayName"
          value="{{ user.displayName }}"
          maxlength="64"
          required
          class="w-full bg-stone-900 border border-stone-700 rounded px-3 py-2 text-stone-100
                 focus:outline-none focus:border-stone-500 transition-colors"
        />
      </div>
      <button type="submit"
              class="px-5 py-2 bg-stone-100 text-stone-900 font-medium rounded hover:bg-white transition-colors">
        Save
      </button>
    </form>
  </section>

  {# ── Change password ── #}
  <section class="border-t border-stone-800 pt-8">
    <h2 class="text-xs font-semibold text-stone-500 uppercase tracking-widest mb-4">Change Password</h2>
    <form method="POST" action="/account/password" class="space-y-4">
      {% include "partials/csrf.njk" %}
      <div>
        <label for="currentPassword" class="block text-sm text-stone-400 mb-1">Current password</label>
        <input
          type="password"
          id="currentPassword"
          name="currentPassword"
          required
          class="w-full bg-stone-900 border border-stone-700 rounded px-3 py-2 text-stone-100
                 focus:outline-none focus:border-stone-500 transition-colors"
        />
      </div>
      <div>
        <label for="newPassword" class="block text-sm text-stone-400 mb-1">New password</label>
        <input
          type="password"
          id="newPassword"
          name="newPassword"
          minlength="8"
          required
          class="w-full bg-stone-900 border border-stone-700 rounded px-3 py-2 text-stone-100
                 focus:outline-none focus:border-stone-500 transition-colors"
        />
      </div>
      <div>
        <label for="confirmPassword" class="block text-sm text-stone-400 mb-1">Confirm new password</label>
        <input
          type="password"
          id="confirmPassword"
          name="confirmPassword"
          minlength="8"
          required
          class="w-full bg-stone-900 border border-stone-700 rounded px-3 py-2 text-stone-100
                 focus:outline-none focus:border-stone-500 transition-colors"
        />
      </div>
      <button type="submit"
              class="px-5 py-2 border border-stone-700 text-stone-400 rounded hover:border-stone-500 transition-colors">
        Change password
      </button>
    </form>
  </section>
</div>
{% endblock %}
