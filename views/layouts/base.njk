<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title %}{{ title }} — {% endif %}Marches</title>
  <link rel="stylesheet" href="/css/app.css" />
  <script src="/js/htmx.min.js" defer></script>
  <style>
    /* HTMX loading indicator */
    .htmx-indicator { opacity: 0; transition: opacity 200ms ease; }
    .htmx-request .htmx-indicator,
    .htmx-request.htmx-indicator { opacity: 1; }
    /* Disable submit buttons during HTMX requests */
    .htmx-request [type="submit"] { pointer-events: none; opacity: 0.5; }
  </style>
</head>
<body class="bg-stone-950 text-stone-100 min-h-screen"
      hx-headers='{"X-CSRF-Token": "{{ csrfToken }}"}'>

  {# ── Top navigation ── #}
  <header class="border-b border-stone-800 bg-stone-900">
    {# ── Primary bar: logo + user ── #}
    <nav class="max-w-6xl mx-auto px-4 h-12 flex items-center justify-between">
      <a href="/" class="font-semibold text-stone-100 tracking-wide">Marches</a>

      <div class="flex items-center gap-4 text-sm">
        {% if user %}
          <span class="text-stone-500 text-xs">{{ user.displayName }}</span>
          <a href="/dashboard" class="text-stone-600 hover:text-stone-400 text-xs">Dashboard</a>
          <a href="/help" class="text-stone-600 hover:text-stone-400 text-xs">Guide</a>
          <a href="/auth/logout"
             onclick="return confirm('Sign out?')"
             class="text-stone-400 hover:text-stone-100 text-xs">Sign out</a>
        {% else %}
          <a href="/auth/login" class="text-stone-400 hover:text-stone-100">Sign in</a>
        {% endif %}
      </div>
    </nav>

    {# ── Campaign tab bar (only inside a campaign) ── #}
    {% if campaign %}
      {% set currentPath = requestPath %}
      {% macro navlink(href, label) %}
        <a href="{{ href }}"
           class="shrink-0 pb-2 border-b-2 text-xs transition-colors
             {{ 'border-stone-400 text-stone-100' if currentPath and currentPath.startsWith(href)
                else 'border-transparent text-stone-500 hover:text-stone-300' }}">
          {{ label }}
        </a>
      {% endmacro %}
      <div class="border-t border-stone-800">
        <div class="max-w-6xl mx-auto px-4 flex items-center gap-5 h-10 overflow-x-auto">
          <a href="/campaigns/{{ campaign.slug }}"
             class="shrink-0 text-xs font-medium text-stone-300 hover:text-stone-100 mr-2">
            {{ campaign.name }}
          </a>
          <span class="text-stone-700 shrink-0">|</span>
          {{ navlink('/campaigns/' + campaign.slug + '/locations', 'Locations') }}
          {{ navlink('/campaigns/' + campaign.slug + '/npcs', 'NPCs') }}
          {{ navlink('/campaigns/' + campaign.slug + '/factions', 'Factions') }}
          {{ navlink('/campaigns/' + campaign.slug + '/artifacts', 'Artifacts') }}
          {{ navlink('/campaigns/' + campaign.slug + '/expeditions', 'Expeditions') }}
          {{ navlink('/campaigns/' + campaign.slug + '/sessions', 'Sessions') }}
          {{ navlink('/campaigns/' + campaign.slug + '/characters', 'Characters') }}
          {{ navlink('/campaigns/' + campaign.slug + '/timeline', 'Timeline') }}
          {% if member and member.role in ['gm', 'admin'] %}
            {{ navlink('/campaigns/' + campaign.slug + '/members', 'Members') }}
          {% endif %}
        </div>
      </div>
    {% endif %}
  </header>

  {# ── HTMX global loading bar ── #}
  <div id="htmx-loading-bar"
       class="htmx-indicator fixed top-0 left-0 right-0 h-0.5 bg-stone-500 z-50"
       hx-trigger="htmx:beforeRequest from:body"
       aria-hidden="true"></div>

  {# ── Flash messages ── #}
  {% if flash %}
    <div class="max-w-6xl mx-auto px-4 pt-4">
      {% if flash.error %}
        <div class="bg-red-900/40 border border-red-700 text-red-300 px-4 py-3 rounded text-sm">
          {{ flash.error }}
        </div>
      {% endif %}
      {% if flash.success %}
        <div class="bg-green-900/40 border border-green-700 text-green-300 px-4 py-3 rounded text-sm">
          {{ flash.success }}
        </div>
      {% endif %}
    </div>
  {% endif %}

  {# ── Main content ── #}
  <main class="max-w-6xl mx-auto px-4 py-8">
    {% block content %}{% endblock %}
  </main>

</body>
</html>
